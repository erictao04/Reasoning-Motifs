  "story_sections": [
    {
      "id": "hypothesis",
      "title": "Reasoning fingerprints",
      "body": "Successful and failed solutions do not just differ in final answers. They often reuse different local reasoning motifs that can be surfaced and compared."
    },
    {
      "id": "method",
      "title": "Method shape",
      "body": "We join raw traces with tokenized traces, mine motifs at the corpus and question level, and then present representative traces alongside the motifs they instantiate."
    },
    {
      "id": "significance",
      "title": "Why it matters",
      "body": "If reasoning traces have structural fingerprints, motifs can become a practical lens for debugging model failures, diagnosing benchmarks, and designing targeted interventions."
    }
  ],
